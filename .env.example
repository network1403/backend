NODE_ENV=development
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=quizzer_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# OR use a single connection string (takes priority if set)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_REFRESH_SECRET=change_this_to_another_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
DATABASE_URL=postgresql://neondb_owner:npg_gC1ivOXnA4Sx@ep-odd-art-aima7j0b-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# Redis (optional - app works without it)
REDIS_URL=redis://localhost:6379

# Frontend URL (for CORS)
FRONTEND_URL=https://frontend-75qu.onrender.com

# Optional: OpenAI for AI question generation
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
